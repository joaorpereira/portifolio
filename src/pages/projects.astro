---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import { resume } from '@/data/resume';
import { isSensitiveContentRevealed } from '@/utils/sensitiveAccess';

if (!isSensitiveContentRevealed(Astro.url)) {
  return Astro.redirect('/');
}
---

<BaseLayout
  title="Projects"
  description="Selected delivery work across climate tech, composable commerce, and design-led product interfaces."
  path="/projects"
  resume={resume}
>
  <PageHeader title="Projects" />
  <div class="grid gap-6 sm:grid-cols-1">
    {resume.projects.map((project) => <ProjectCard project={project} />)}
  </div>
</BaseLayout>

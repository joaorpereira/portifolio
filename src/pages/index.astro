---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ContactSection from '@/components/ContactSection.astro';
import { resume } from '@/data/resume';
import { withHttps } from '@/utils/links';
import { resolveMediaSrc } from '@/utils/media';

const { basics, experience, projects } = resume;
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');

const withBase = (path: string): string => {
  if (!basePath) return path;
  if (path === '/') return `${basePath}/`;
  return `${basePath}${path}`;
};

const highlights = [
  {
    title: 'Performance & cost',
    body: 'Shipped measurable Lighthouse gains and large infra savings through caching and query work.',
  },
  {
    title: 'Composable commerce',
    body: 'Deep experience across Commercetools, Contentful, Elastic Path, and Bold in production B2C/B2B builds.',
  },
  {
    title: 'Quality bar',
    body: 'WCAG-minded UI, Jest/RTL unit tests, and Playwright coverage for critical flows.',
  },
];

const currentRole = experience[0];
const profileSrc = basics.profileImage ? resolveMediaSrc(basics.profileImage) : '';
---

<BaseLayout
  title="João Paulo Pereira"
  description={basics.summary.slice(0, 155)}
  path="/"
  resume={resume}
>
  <section class="animate-fade-up" aria-labelledby="hero-heading">
    <div
      class="flex flex-col-reverse gap-8 sm:gap-9 lg:flex-row lg:flex-row-reverse lg:items-center lg:gap-10 xl:gap-12"
    >
      {
        profileSrc && (
          <figure
            class="mx-auto shrink-0 lg:mx-0 lg:pt-1"
            aria-hidden="true"
          >
            <div
              class="overflow-hidden rounded-2xl bg-ink-100 shadow-md ring-1 ring-ink-200/90 dark:bg-ink-900 dark:ring-ink-700/80 w-[10.5rem] sm:w-[11.25rem] lg:w-[12rem]"
            >
              <img
                src={profileSrc}
                alt=""
                width={384}
                height={512}
                class="aspect-[3/4] w-full object-cover object-[center_20%]"
                loading="eager"
                decoding="async"
              />
            </div>
          </figure>
        )
      }
      <div class="min-w-0 flex-1">
        <p class="text-sm font-medium uppercase tracking-wider text-ink-600 dark:text-ink-300">
          {basics.label}
        </p>
        <h1
          id="hero-heading"
          class="mt-3 font-display text-4xl font-semibold tracking-tight text-ink-950 dark:text-ink-50 sm:text-5xl"
        >
          {basics.name}
        </h1>
        <p class="mt-5 max-w-2xl text-lg leading-relaxed text-ink-700 dark:text-ink-200">
          {basics.summary}
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href={withBase('/resume')}
            data-reveal-link
            class="inline-flex items-center justify-center rounded-lg bg-ink-950 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-ink-800 dark:bg-white dark:text-ink-950 dark:hover:bg-ink-100"
          >
            View resume
          </a>
          <a
            data-sensitive
            href={withHttps(basics.github)}
            class="inline-flex items-center justify-center rounded-lg border border-ink-300 bg-transparent px-4 py-2.5 text-sm font-semibold text-ink-900 transition hover:border-ink-400 hover:bg-ink-100 dark:border-ink-600 dark:text-ink-100 dark:hover:border-ink-500 dark:hover:bg-ink-900"
            rel="noopener noreferrer"
            target="_blank"
          >
            GitHub
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="mt-16 animate-fade-up" style="animation-delay: 80ms" aria-labelledby="current-heading">
    <h2 id="current-heading" class="font-display text-xl font-semibold text-ink-950 dark:text-ink-50">
      Currently
    </h2>
    <p class="mt-3 text-ink-700 dark:text-ink-200">
      <span class="font-semibold text-ink-950 dark:text-white">{currentRole.role}</span>
      {' '}at{' '}
      <span class="font-medium text-accent dark:text-accent-muted">{currentRole.company}</span>
      {' '}
      · {currentRole.location}
    </p>
    <ul class="mt-4 list-inside list-disc space-y-2 text-sm text-ink-600 dark:text-ink-300">
      {currentRole.highlights?.slice(0, 3).map((h) => <li class="pl-1">{h}</li>)}
    </ul>
    <a
      data-sensitive
      data-reveal-link
      href={withBase('/projects')}
      class="mt-4 inline-block text-sm font-semibold text-accent underline-offset-4 hover:underline dark:text-accent-muted"
    >
      See selected projects →
    </a>
    <p data-reveal-fallback class="mt-4 text-sm font-semibold text-ink-600 dark:text-ink-300">
      Selected projects are highlighted below.
    </p>
  </section>

  <section class="mt-16 animate-fade-up" style="animation-delay: 120ms" aria-labelledby="highlights-heading">
    <h2 id="highlights-heading" class="font-display text-xl font-semibold text-ink-950 dark:text-ink-50">
      How I work
    </h2>
    <div class="mt-6 grid gap-4 sm:grid-cols-3">
      {
        highlights.map((h) => (
          <div class="rounded-2xl border border-ink-200 bg-white p-5 dark:border-ink-800 dark:bg-ink-900/50">
            <h3 class="text-sm font-semibold text-ink-950 dark:text-ink-50">{h.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-600 dark:text-ink-300">{h.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="mt-16 animate-fade-up" style="animation-delay: 160ms" aria-labelledby="home-projects-heading">
    <div class="flex items-end justify-between gap-4">
      <h2 id="home-projects-heading" class="font-display text-xl font-semibold text-ink-950 dark:text-ink-50">
        Projects
      </h2>
      <a
        data-sensitive
        data-reveal-link
        href={withBase('/projects')}
        class="text-sm font-semibold text-accent underline-offset-4 hover:underline dark:text-accent-muted"
      >
        All projects
      </a>
    </div>
    <ul class="mt-8 grid gap-6 sm:grid-cols-2">
      {
        projects.map((p) => {
          const img = p.image ? resolveMediaSrc(p.image) : '';
          const hasVideo = Boolean(p.video?.trim());
          const subtitle = [p.company, p.period].filter(Boolean).join(' · ');
          const cardShell =
            'flex h-full flex-col overflow-hidden rounded-2xl border border-ink-200 bg-white shadow-md shadow-black/10 ring-1 ring-black/[0.04] dark:border-ink-700/55 dark:bg-ink-900 dark:shadow-lg dark:shadow-black/45 dark:ring-white/[0.04]';
          const cardInteractive =
            'transition hover:border-ink-300 hover:shadow-lg dark:hover:border-accent/45 dark:hover:shadow-xl dark:hover:shadow-black/55';
          return (
            <li>
              <a
                data-sensitive-card
                data-reveal-link
                href={withBase('/projects')}
                class:list={[cardShell, cardInteractive, 'group']}
              >
                <div class="relative aspect-[16/10] w-full overflow-hidden border-b border-ink-200 bg-ink-100 dark:border-ink-800 dark:bg-ink-950">
                  {img ? (
                    <img
                      src={img}
                      alt=""
                      width={640}
                      height={400}
                      class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.02]"
                      loading="lazy"
                      decoding="async"
                    />
                  ) : (
                    <div
                      class="flex h-full w-full items-center justify-center bg-ink-100 p-6 dark:bg-ink-950"
                      aria-hidden="true"
                    >
                      <img
                        src={withBase('/images/project-placeholder.svg')}
                        alt=""
                        width={640}
                        height={400}
                        class="h-full w-full max-h-full object-contain opacity-90 transition duration-300 group-hover:opacity-100 dark:opacity-95"
                        loading="lazy"
                        decoding="async"
                      />
                    </div>
                  )}
                  {hasVideo && (
                    <span
                      class="absolute left-3 top-3 rounded-full bg-black/70 px-2.5 py-1 text-xs font-semibold text-white ring-1 ring-white/25"
                    >
                      Video demo
                    </span>
                  )}
                </div>
                <div class="flex flex-1 flex-col bg-white p-5 sm:p-6 dark:bg-ink-900">
                  <h3 class="font-display text-lg font-semibold text-ink-950 dark:text-ink-50">{p.name}</h3>
                  {subtitle && (
                    <p class="mt-1 text-sm text-ink-600 dark:text-ink-300">{subtitle}</p>
                  )}
                  {p.summary && (
                    <p class="mt-3 text-sm leading-relaxed text-ink-700 dark:text-ink-200">{p.summary}</p>
                  )}
                </div>
              </a>
            </li>
          );
        })
      }
    </ul>
  </section>

  <div data-sensitive class="mt-16 animate-fade-up" style="animation-delay: 200ms">
    <ContactSection
      email={basics.email}
      github={basics.github}
      linkedin={basics.linkedin}
      resumePdf={basics.resumePdf}
    />
  </div>
</BaseLayout>

---
import '@/styles/global.css';
import SEO from '@/components/SEO.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import Container from '@/components/Container.astro';
import type { Resume } from '@/types/resume';
import { isSensitiveContentRevealed } from '@/utils/sensitiveAccess';

interface Props {
  title: string;
  description: string;
  path?: string;
  resume: Resume;
}

const { title, description, path = '/', resume } = Astro.props;
const requestUrl = Astro.url;
const revealSensitive = isSensitiveContentRevealed(requestUrl);
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <SEO title={title} description={description} path={path} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('theme');
          var dark = t !== 'light';
          document.documentElement.classList.toggle('dark', dark);
        } catch (e) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="flex min-h-full flex-col">
    <Header revealSensitive={revealSensitive} requestUrl={requestUrl} />
    <main id="main" class="flex-1 py-10 sm:py-14">
      <Container>
        <slot />
      </Container>
    </main>
    <Footer
      revealSensitive={revealSensitive}
      github={resume.basics.github}
      linkedin={resume.basics.linkedin}
      email={resume.basics.email}
    />
    <script is:inline>
      (function () {
        var btn = document.getElementById('theme-toggle');
        if (!btn) return;
        btn.addEventListener('click', function () {
          var root = document.documentElement;
          var on = root.classList.toggle('dark');
          try {
            localStorage.setItem('theme', on ? 'dark' : 'light');
          } catch (e) {}
        });
      })();
    </script>
  </body>
</html>

---
interface Props {
  title: string;
  description: string;
  path?: string;
  /** Absolute URL or site-relative path (e.g. /og.png) */
  image?: string;
}

const { title, description, path = '/', image } = Astro.props;
const site = Astro.site?.href.replace(/\/$/, '') ?? '';
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const canonicalPath = path.startsWith('/') && basePath ? `${basePath}${path}` : path;
const canonical = new URL(canonicalPath, site || Astro.url.origin).href;
const origin = site || Astro.url.origin;
const ogImage =
  image &&
  (image.startsWith('http')
    ? image
    : new URL(
        image.startsWith('/') && basePath
          ? `${basePath}${image}`.replace(/^\//, '')
          : image.replace(/^\//, ''),
        `${origin}/`
      ).href);
const fullTitle = path === '/' ? title : `${title} · João Paulo Pereira`;
const twitterCard = ogImage ? 'summary_large_image' : 'summary';
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="theme-color" content="#141f1a" />
<meta name="color-scheme" content="dark light" />
<meta name="generator" content={Astro.generator} />
<link rel="canonical" href={canonical} />

<title>{fullTitle}</title>
<meta name="description" content={description} />
<meta name="author" content="João Paulo Rodrigues Pereira" />

<meta property="og:type" content="website" />
<meta property="og:url" content={canonical} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
{ogImage && <meta property="og:image" content={ogImage} />}
<meta property="og:locale" content="en_US" />

<meta name="twitter:card" content={twitterCard} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
{ogImage && <meta name="twitter:image" content={ogImage} />}

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:ital,opsz,wght@0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700;1,14..32,400&display=swap"
  rel="stylesheet"
/>

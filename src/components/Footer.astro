---
import Container from '@/components/Container.astro';
import { withHttps } from '@/utils/links';

interface Props {
  revealSensitive: boolean;
  github: string;
  linkedin: string;
  email: string;
}

const { revealSensitive, github, linkedin, email } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="mt-20 border-t border-ink-200 bg-ink-100 py-10 dark:border-ink-800 dark:bg-ink-950">
  <Container class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
    <p class="text-sm text-ink-600 dark:text-ink-300">
      © {year} João Paulo Rodrigues Pereira
    </p>
    {
      revealSensitive && (
        <ul class="flex flex-wrap gap-x-6 gap-y-2 text-sm font-medium">
          <li>
            <a
              class="text-ink-800 underline-offset-4 transition hover:text-accent hover:underline dark:text-ink-200 dark:hover:text-accent-muted"
              href={withHttps(github)}
              rel="noopener noreferrer"
              target="_blank"
            >
              GitHub
            </a>
          </li>
          <li>
            <a
              class="text-ink-800 underline-offset-4 transition hover:text-accent hover:underline dark:text-ink-200 dark:hover:text-accent-muted"
              href={withHttps(linkedin)}
              rel="noopener noreferrer"
              target="_blank"
            >
              LinkedIn
            </a>
          </li>
          <li>
            <a
              class="text-ink-800 underline-offset-4 transition hover:text-accent hover:underline dark:text-ink-200 dark:hover:text-accent-muted"
              href={`mailto:${email}`}
            >
              Email
            </a>
          </li>
        </ul>
      )
    }
  </Container>
</footer>

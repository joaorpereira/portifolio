---
import type { Experience } from '@/types/resume';
import { formatExperienceRange } from '@/utils/dates';

interface Props {
  job: Experience;
}

const { job } = Astro.props;
const range = formatExperienceRange(job.startDate, job.endDate);
---

<article
  class="group rounded-2xl border border-ink-200 bg-white p-6 shadow-sm transition hover:border-ink-300 dark:border-ink-800 dark:bg-ink-900/50 dark:hover:border-ink-700 sm:p-7"
>
  <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
    <div>
      <h2 class="font-display text-lg font-semibold text-ink-950 dark:text-ink-50 sm:text-xl">
        {job.role}
      </h2>
      <p class="text-base font-medium text-accent dark:text-accent-muted">{job.company}</p>
    </div>
    <p class="text-sm tabular-nums text-ink-500 dark:text-ink-300">{range}</p>
  </div>
  <p class="mt-1 text-sm text-ink-600 dark:text-ink-300">{job.location}</p>

  {
    job.highlights && job.highlights.length > 0 && (
      <ul class="mt-4 list-inside list-disc space-y-2 text-sm leading-relaxed text-ink-700 marker:text-ink-400 dark:text-ink-200 dark:marker:text-ink-400 sm:text-[0.9375rem]">
        {job.highlights.map((item) => (
          <li class="pl-1">{item}</li>
        ))}
      </ul>
    )
  }

  {
    job.projects && job.projects.length > 0 && (
      <div class="mt-6 space-y-5 border-t border-ink-100 pt-6 dark:border-ink-800">
        {job.projects.map((p) => (
          <div>
            <h3 class="text-sm font-semibold text-ink-900 dark:text-ink-100">{p.name}</h3>
            <ul class="mt-2 list-inside list-disc space-y-1.5 text-sm leading-relaxed text-ink-600 dark:text-ink-300">
              {p.highlights.map((h) => (
                <li class="pl-1">{h}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    )
  }
</article>

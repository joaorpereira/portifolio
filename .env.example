# Copy to `.env` (local dev + deploy.sh) and optionally `.env.production` (astro build).
# Both real env files are gitignored.

# Contact & social (shown only when the client-side gate is unlocked)
PUBLIC_CONTACT_EMAIL=
PUBLIC_CONTACT_GITHUB=
PUBLIC_CONTACT_LINKEDIN=

# URL query gate (?KEY=VALUE unlocks sensitive UI for this browser session)
PUBLIC_SENSITIVE_QUERY_KEY=password
PUBLIC_SENSITIVE_QUERY_VALUE=

# --- Used by infra/deploy.sh (optional if you pass env another way) ---
# CFN_STACK_NAME=joao-portfolio-site
# S3_BUCKET=
# CLOUDFRONT_DISTRIBUTION_ID=
# AWS_PROFILE=
